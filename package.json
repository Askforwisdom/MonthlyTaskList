{
  "name": "tasklist-desktop",
  "version": "2.0.0",
  "description": "月度任务清单桌面应用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --dir"
  },
  "keywords": [
    "task",
    "todo",
    "electron",
    "desktop"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.tasklist.desktop",
    "productName": "月度任务清单",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.html",
      "renderer.js"
    ],
    "win": {
      "target": "dir"
    },
    "asar": true
  }
}
